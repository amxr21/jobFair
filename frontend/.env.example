# Frontend Environment Variables
# Copy this file to .env and fill in your values

# ─── DB / Demo mode ───────────────────────────────────────────────────────────
# VITE_DB_MODE controls which backend URL the frontend uses.
#   "demo"       → http://localhost:2000  (in-memory, no DB needed)
#   "local"      → http://localhost:2000  (real MongoDB locally)
#   "production" → https://jobfair-7zaa.onrender.com (deployed backend)
#
# VITE_API_URL overrides VITE_DB_MODE if you need a custom URL.
# ─────────────────────────────────────────────────────────────────────────────

# Uncomment ONE of the lines below:
VITE_DB_MODE=demo
# VITE_DB_MODE=local
# VITE_DB_MODE=production

# Optional: override the URL completely
# VITE_API_URL=http://localhost:2000

# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Demo / DB mode ────────────────────────────────────────────────────────────
# Set DEMO_MODE=true to run with in-memory sample data (no MongoDB, no Cloudinary).
# Set DEMO_MODE=false (or remove) to use the real MongoDB database.
DEMO_MODE=true

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=2000

# ─── MongoDB (not required when DEMO_MODE=true) ────────────────────────────────
# Variable name must be URI (not MONGODB_URI)
URI=mongodb://localhost:27017/jobfair

# ─── JWT (not required when DEMO_MODE=true) ────────────────────────────────────
TOKEN_SIGN=your_jwt_secret_key_here

# ─── Cloudinary (not required when DEMO_MODE=true) ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email / Nodemailer (not required when DEMO_MODE=true) ────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

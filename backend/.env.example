# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Demo / DB mode ────────────────────────────────────────────────────────────
# Set DEMO_MODE=true to run with in-memory sample data (no MySQL, no Cloudinary).
# Set DEMO_MODE=false (or remove) to use the real MySQL database via Prisma.
DEMO_MODE=true

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=2000

# ─── MySQL / Prisma (not required when DEMO_MODE=true) ─────────────────────────
# Any special characters in the username/password (e.g. @, :, /) must be
# percent-encoded (@ -> %40) or Prisma will mis-parse the host/port.
DATABASE_URL=mariadb://user:password@localhost:3306/jobfair

# ─── JWT (not required when DEMO_MODE=true) ────────────────────────────────────
TOKEN_SIGN=your_jwt_secret_key_here

# ─── Cloudinary (not required when DEMO_MODE=true) ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email / Nodemailer (not required when DEMO_MODE=true) ────────────────────
# Outbound email is OFF by default. Nothing is ever sent unless EMAIL_ENABLED=true.
# While off, every send is logged (subject/to/from) instead of dispatched — safe
# for testing without spamming real recipients. Set to true only when you
# intentionally want real emails to go out.
EMAIL_ENABLED=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
